{
  "compilerOptions": {
    "noImplicitAny": true,
    "module": "es6",
    "target": "es6",
    "lib": ["DOM", "esnext"],
    "strict": true,
    "allowJs": false,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "declaration": true,
    "isolatedModules": true,
    "stripInternal": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": ["dist", "node_modules"]
}
